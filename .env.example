# Copy this file to .env and fill in your values.
# .env is gitignored and never committed to source control.

# API key obtained from the Fing mobile app:
#   App > Network > Agents > [your agent] > Settings > Local API
FING_API_KEY=your_api_key_here

# IP of the QNAP NAS running fing-agent-familypotter (CALGARYHOUSE)
FING_AGENT_HOST=192.168.0.150

# IP of the physical Fingbox device on your network
FINGBOX_HOST=192.168.0.144

# Local API port (default: 49090)
FING_LOCAL_API_PORT=49090
